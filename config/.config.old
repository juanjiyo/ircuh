#
# Automatically generated by 'make config': don't edit
#
CHANGE_CONFIG=n

#
# Compile stuff
#
CC="gcc"
CFLAGS="-g -O3 -pipe"
cflags_O3_remark="done"
EXTRA_INCLUDEDIRS="none"
LDFLAGS="none"
IRCDLIBS="-lresolv -lcrypt"
BINDIR="/home/irc/ircu/bin"
SYMLINK="ircd"
IRCDMODE="711"
IRCDOWN="irc"
IRCDGRP="irc"
MANDIR="/home/irc/ircu/share/man"
EXTRA_CPPFLAGS=""
CPPFLAGS="-I../include"
FORCEINLINE=y

#
# Host specific defines
#
DOMAINNAME="irc.mundichat.com"

#
# General defines
#
CHROOTDIR=n
CONFIG_SETUGID=n
IRC_UID=
IRC_GID=
CMDLINE_CONFIG=n
VIRTUAL_HOST=n
HUB=y

#
# Debugging (do not define this on production servers)
#
DEBUGMODE=n
DEBUGMALLOC=n
NODNS=n

#
# Paths and files
#
DPATH="/home/irc/ircu/etc"
SPATH="/home/irc/ircu/bin/ircd"
CPATH="ircd.conf"
MPATH="ircd.motd"
RPATH="remote.motd"
PPATH="ircd.pid"

#
# Logging (filenames are either full paths or files within DPATH)
#
CONFIG_LOG_WHOX=y
WPATH="whox.log"
CONFIG_LOG_GLINES=n
CONFIG_LOG_USERS=n
CONFIG_LOG_OPERS=n
USE_SYSLOG=n

#
# Configuration
#
CRYPT_OPER_PASSWORD=y
BUFFERPOOL=27000000
FERGUSON_FLUSHER=n
CLIENT_FLOOD=1536
MAXCONNECTIONS=3500
PORTNUM=6667
NICKNAMEHISTORYLENGTH=800
ALLOW_SNO_CONNEXIT=n
R_LINES=n
NODEFAULTMOTD=y

#
# Oper commands
#
SHOW_INVISIBLE_USERS=y
SHOW_ALL_INVISIBLE_USERS=y
WHOX_HELPERS=y
OPERS_SEE_IN_SECRET_CHANNELS=y
LOCOP_SEE_IN_SECRET_CHANNELS=n
UNLIMIT_OPER_QUERY=n
OPER_KILL=y
OPER_REHASH=y
OPER_RESTART=y
OPER_DIE=y
OPER_LGLINE=y
OPER_REMOTE=y
OPER_JOIN_GOD_ESNET=y
OPER_CHANNEL_SERVICE_ESNET=y
CS_NO_FLOOD_ESNET=y
LOCOP_REHASH=y
LOCOP_RESTART=y
LOCOP_DIE=y
LOCOP_LGLINE=y
OPER_NO_CHAN_LIMIT=y
OPER_MODE_LCHAN=y
OPER_WALK_THROUGH_LMODES=n
NO_OPER_DEOP_LCHAN=n

#
# Server characteristics
#
CONFIG_LIST=y
DEFAULT_LIST="T<10"
DEFAULT_LIST_PARAM="T<10"
COMMENT_IS_FILE=y
IDLE_FROM_MSG=y
CHECK_TS_LINKS=y

#
# Mandatory defines (you should leave these untouched)
#
DBPATH="database"
BDD_MMAP=y
BDD_MMAP_PATH="ircd-database.mmap"
BDD_MMAP_SIZE=16
BDD_CLONES=y
BDD_CHAN_HACK=y
BDD_OPER_HACK=y
BDD_OPER_HACK_KMODE=y
BDD_VIP=y
BDD_VIP3=n
BDD_VIP2=y
ESNET_NEG=y
ZLIB_ESNET=y
WEBCHAT=n
MAXIMUM_LINKS=2
MSGLOG_ENABLED=n
LOCAL_KILL_ONLY=n
KILLCHASETIMELIMIT=30
MAXCHANNELSPERUSER=10
MAXSILES=25
MAXWATCH=96
AVBANLEN=40
MAXSILELENGTH="(40 * MAXSILES)"
TIMESEC=60
PINGFREQUENCY=120
CONNECTFREQUENCY=600
HANGONGOODLINK=300
HANGONRETRYDELAY=10
CONNECTTIMEOUT=90
DEFAULTMAXSENDQLENGTH=40000
